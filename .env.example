# ==============================================================
# AI AGENT — SMART DATA ANALYST | Environment Variables Template
# ==============================================================
# QUY TẮC: TUYỆT ĐỐI KHÔNG ĐIỀN MẬT KHẨU THẬT VÀO FILE NÀY!
# Hướng dẫn cho TV3/TV4: Copy file này thành thư mục `backend/.env` 
# và điền các mật khẩu thật do TV1/TV2 cấp vào đó.
# ==============================================================

# --- DATABRICKS CONNECTION (Dùng Service Principal OAuth M2M) ---
DATABRICKS_HOST=dbc-xxxxxxxxxxxxx.cloud.databricks.com
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/xxxxxxxxxxxxxx
DATABRICKS_CLIENT_ID=<điền-client-id-mà-TV1-đã-cấp>
DATABRICKS_CLIENT_SECRET=<điền-secret-key-mà-TV1-đã-cấp>
DATABRICKS_CATALOG=ai_analyst
DATABRICKS_SCHEMA=ecommerce

# --- LLM CONFIGURATION ---
LLM_PROVIDER=gemini
GEMINI_API_KEY=<điền-key-của-bạn-vào-đây>
GEMINI_MODEL=gemini-2.5-flash

# --- APP SETTINGS ---
APP_ENV=development
APP_PORT=8000
LOG_LEVEL=INFO
SQL_MAX_LIMIT=1000
SQL_QUERY_TIMEOUT=30
